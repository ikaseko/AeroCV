        "bestFor": [
          "tech",
          "corporate",
          "professional",
          "modern"
        ],
        "assetsPath": "templates/modern-cv/assets/typst_assets.zip",
        "languages": 35,
        "hasCoverLetter": true,
        "supportsPhoto": true,
        "photoType": "circular",
        "keyFeatures": [
          "Clean modern design",
          "FontAwesome icons",
          "Multi-language",
          "Customizable colors",
          "Profile photo support (circular)"
        ]
      },
