        "assetsPath": "templates/neat-cv/assets/typst_assets.zip",
        "languages": 2,
        "hasCoverLetter": true,
        "supportsPhoto": true,
        "photoType": "rectangular-left",
        "keyFeatures": [
          "Bilingual (EN/FR)",
          "Content separation",
          "Profile photo (left side)",
          "Source Sans Pro fonts included"
        ]
