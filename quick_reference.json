{
  "$schema": "./schemas/quick_reference.schema.json",
  "version": "1.0.0",
  "description": "Quick reference guide for GPT agents to discover and select templates",
  "howToUse": {
    "step1": "Read this file to understand available templates",
    "step2": "Use templates_registry.json for detailed template information",
    "step3": "Use the 'paths.assets' to locate the ZIP file for compilation",
    "step4": "Reference the 'sections' to understand available document structures"
  },
  "availableTemplates": {
    "resumes": [
