          "Self-contained package"
        ]
      },
      {
        "id": "vantage",
        "name": "Vantage",
        "bestFor": [
          "tech",
          "clean"
        ],
        "assetsPath": "templates/vantage/assets/typst_assets.zip",
        "languages": 1,
