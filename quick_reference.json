    "coverLetters": [
      {
        "id": "modern-cv-cover-letter",
        "name": "Modern CV Cover Letter",
        "matchesResume": "modern-cv",
        "assetsPath": "cover_letters/modern-cv/assets/typst_assets.zip",
        "keyFeatures": [
          "Matches resume design",
          "Professional layout",
          "Signature support"
        ]
      },
      {
        "id": "designer-cover-letter",
        "name": "Designer Cover Letter",
        "matchesResume": "designer-cv",
        "assetsPath": "cover_letters/designer-cover-letter/assets/typst_assets.zip",
        "keyFeatures": [
          "Matches designer-cv design"
        ]
      },
      {
        "id": "executive-cover-letter",
        "name": "Executive Cover Letter",
        "matchesResume": "executive-cv",
        "assetsPath": "cover_letters/executive-cover-letter/assets/typst_assets.zip",
        "keyFeatures": [
          "Matches executive-cv design"
        ]
      },
      {
        "id": "portfolio-cover-letter",
        "name": "Portfolio Cover Letter",
        "matchesResume": "portfolio-cv",
        "assetsPath": "cover_letters/portfolio-cover-letter/assets/typst_assets.zip",
        "keyFeatures": [
          "Matches portfolio-cv design"
        ]
      }
    ]
  },
  "quickCommands": {
    "modern-cv": {
      "experience": "#resume-entry(title: \"Job Title\", location: \"Company\", date: \"2020-2024\")",
      "education": "#resume-entry(title: \"University\", location: \"Degree\", date: \"2016-2020\")",
      "skills": "#resume-skill-item(\"Category\", (\"Skill 1\", \"Skill 2\"))"
    },
    "modern-cv-cover-letter": {
      "header": "#cover-letter-header(sender: ..., recipient: ...)",
      "body": "#cover-letter-body[...] ",
      "closing": "#cover-letter-closing(\"Sincerely,\")"
    },
    "designer-cv": {
      "experience": "#resume-entry(...)",
      "education": "#resume-entry(...)",
      "skills": "#resume-skill-item(...)"
    },
    "executive-cv": {
      "experience": "#resume-entry(...)",
      "education": "#resume-entry(...)",
      "skills": "#resume-skill-item(...)"
    },
    "portfolio-cv": {
      "experience": "#resume-entry(...)",
      "education": "#resume-entry(...)",
      "skills": "#resume-skill-item(...)"
    }
  },
  "compilation": {
    "engine": "typst",
    "offline": true,
    "command": "./typst compile --font-path fonts resume.typ",
    "outputFormat": "pdf"
  },
  "fileStructure": {
    "templates": "templates/<template-id>/",
    "assets": "templates/<template-id>/assets/typst_assets.zip",
    "images": "template_images/resumes/<template-id>-preview.png",
    "coverLetters": "cover_letters/<template-id>/",
    "output": "output/"
  },
  "photoSupport": {
    "detection": "Check /mnt/data/ for uploaded PNG/JPG files",
    "skipFiles": [
      "avatar.png",
      "profile.png",
      "signature.png",
      "picture.png",
      "photo.png",
      "thumbnail.png"
    ],
    "templates": {
      "modern-cv": {
        "parameter": "profile-picture",
        "syntax": "profile-picture: image(\"path/to/photo.png\")",
        "display": "circular",
        "position": "header-right"
      },
      "typst-cv": {
        "parameter": "picture",
        "syntax": "picture = \"path/to/photo.png\"",
        "display": "rectangular",
        "position": "header-grid"
      },
      "brilliant-cv": {
        "parameter": "display_profile_photo",
        "syntax": "display_profile_photo = true; profile_photo_path = \"path/to/photo.png\"",
        "display": "circular-configurable",
        "position": "header-left"
      },
      "neat-cv": {
        "parameter": "profilePhoto",
        "syntax": "#let profilePhoto = \"path/to/photo.png\"",
        "display": "rectangular",
        "position": "left-sidebar"
      },
      "vercanard": {
        "supported": false,
        "note": "No photo support"
      },
      "vantage": {
        "supported": false,
        "note": "No photo support"
      },
      "designer-cv": {
        "parameter": "profile-picture",
        "syntax": "profile-picture: image(\"path/to/photo.png\")",
        "display": "standard",
        "position": "header-right"
      },
      "executive-cv": {
        "parameter": "profile-picture",
        "syntax": "profile-picture: image(\"path/to/photo.png\")",
        "display": "standard",
        "position": "header-right"
      },
      "portfolio-cv": {
        "parameter": "profile-picture",
        "syntax": "profile-picture: image(\"path/to/photo.png\")",
        "display": "standard",
        "position": "header-right"
      }
    }
  }
}